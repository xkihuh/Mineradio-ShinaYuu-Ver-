{
  "name": "shinayuu-music",
  "productName": "ShinaYuu Music",
  "version": "1.1.2",
  "description": "Trình phát nhạc hình ảnh Việt–Anh cho Windows với Spotify, YouTube và Discord Rich Presence.",
  "author": "ShinaYuu",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:win": "electron-builder --win nsis",
    "build:win:dir": "electron-builder --win dir",
    "preview:win": "node build/preview-win.js",
    "test": "node tests/provider-regression.test.js && node tests/spotify-auth-regression.test.js && node tests/spotify-direct-player-regression.test.js && node tests/realtime-playback-regression.test.js && node tests/lyrics-sync-regression.test.js && node tests/spotify-lyrics-regression.test.js && node tests/ui-regression.test.js && node tests/packaging-regression.test.js && node tests/spotify-host-visibility-regression.test.js && node tests/discord-ipc-client-regression.test.js && node tests/discord-presence-regression.test.js",
    "test:providers": "node tests/provider-regression.test.js",
    "test:spotify": "node tests/spotify-direct-player-regression.test.js",
    "test:ui": "node tests/ui-regression.test.js",
    "test:packaging": "node tests/packaging-regression.test.js",
    "test:spotify-auth": "node tests/spotify-auth-regression.test.js",
    "test:discord": "node tests/discord-ipc-client-regression.test.js && node tests/discord-presence-regression.test.js",
    "test:lyrics": "node tests/lyrics-sync-regression.test.js && node tests/spotify-lyrics-regression.test.js"
  },
  "build": {
    "appId": "com.shinayuu.music",
    "productName": "ShinaYuu Music",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "music-providers.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": false,
    "win": {
      "executableName": "ShinaYuuMusic",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShinaYuu Music",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "ShinaYuu-Music-${version}-Setup.${ext}"
    }
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "",
      "repo": "",
      "preview": false,
      "preferMirrors": false,
      "mirrors": []
    }
  },
  "dependencies": {
    "@webviewjs/webview": "0.4.0",
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "youtubei.js": "^17.2.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "shinayuu": {
    "discord": {
      "applicationId": "",
      "largeImageKey": "shinayuu",
      "largeImageText": "ShinaYuu Music"
    }
  }
}
