{
  "name": "shinayuu-music",
  "productName": "ShinaYuu Music",
  "version": "1.1.5",
  "description": "A Windows visual music player powered by Castlabs Electron with Spotify, YouTube, synchronized lyrics, Discord Rich Presence, and integrated master volume control.",
  "author": "ShinaYuu",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "node tools/ensure-castlabs-runtime.js && electron .",
    "dev": "node tools/ensure-castlabs-runtime.js && electron .",
    "build:win": "node tools/build-windows-release.js",
    "build:win:dir": "node tools/ensure-castlabs-runtime.js && node tools/verify-castlabs-runtime.js && electron-builder --win dir",
    "preview:win": "node build/preview-win.js",
    "test": "node tests/liquid-glass-home-regression.test.js && node tests/youtube-account-regression.test.js && node tests/local-library-regression.test.js && node tests/playback-prefetch-regression.test.js && node tests/audio-session-bridge-regression.test.js && node tests/localization-regression.test.js && node tests/lyric-calibration-panel-regression.test.js && node tests/master-volume-regression.test.js && node tests/castlabs-electron-regression.test.js && node tests/youtube-music-lyrics-regression.test.js && node tests/youtube-caption-lyrics-regression.test.js && node tests/youtube-forced-alignment-regression.test.js && node tests/provider-regression.test.js && node tests/spotify-auth-regression.test.js && node tests/spotify-direct-player-regression.test.js && node tests/spotify-seek-lyrics-recovery-regression.test.js && node tests/realtime-playback-regression.test.js && node tests/lyrics-sync-regression.test.js && node tests/spotify-lyrics-regression.test.js && node tests/ui-regression.test.js && node tests/packaging-regression.test.js && node tests/discord-ipc-client-regression.test.js && node tests/discord-presence-regression.test.js",
    "test:providers": "node tests/provider-regression.test.js",
    "test:spotify": "node tests/spotify-direct-player-regression.test.js && node tests/spotify-seek-lyrics-recovery-regression.test.js",
    "test:ui": "node tests/ui-regression.test.js",
    "test:packaging": "node tests/packaging-regression.test.js",
    "test:spotify-auth": "node tests/spotify-auth-regression.test.js",
    "test:discord": "node tests/discord-ipc-client-regression.test.js && node tests/discord-presence-regression.test.js",
    "test:lyrics": "node tests/lyrics-sync-regression.test.js && node tests/spotify-lyrics-regression.test.js",
    "test:youtube-lyrics": "node tests/youtube-caption-lyrics-regression.test.js && node tests/youtube-forced-alignment-regression.test.js",
    "test:youtube-music-lyrics": "node tests/youtube-music-lyrics-regression.test.js",
    "test:volume": "node tests/master-volume-regression.test.js",
    "test:audio-session": "node tests/audio-session-bridge-regression.test.js",
    "test:localization": "node tests/localization-regression.test.js",
    "test:lyric-panel": "node tests/lyric-calibration-panel-regression.test.js",
    "setup:castlabs": "node tools/ensure-castlabs-runtime.js",
    "verify:castlabs": "node tools/verify-castlabs-runtime.js",
    "test:castlabs": "node tests/castlabs-electron-regression.test.js",
    "build:win:unsigned": "node tools/build-windows-release.js --unsigned",
    "build:win:installer": "electron-builder --win nsis --prepackaged dist/win-unpacked",
    "sign:evs:runtime": "node tools/evs-package.js sign node_modules/electron/dist",
    "verify:evs:runtime": "node tools/evs-package.js verify node_modules/electron/dist",
    "sign:evs:package": "node tools/evs-package.js sign dist/win-unpacked",
    "verify:evs:package": "node tools/evs-package.js verify dist/win-unpacked",
    "test:local-library": "node tests/local-library-regression.test.js",
    "test:youtube-account": "node tests/youtube-account-regression.test.js"
  },
  "build": {
    "appId": "com.shinayuu.music",
    "productName": "ShinaYuu Music",
    "afterSign": "build/evs-after-sign.js",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "music-providers.js",
      "local-library.js",
      "youtube-caption-provider.js",
      "youtube-forced-aligner.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": false,
    "win": {
      "executableName": "ShinaYuuMusic",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShinaYuu Music",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "ShinaYuu-Music-1.1.5-Setup.${ext}"
    },
    "buildVersion": "1.1.5",
    "electronDist": "node_modules/electron/dist"
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "",
      "repo": "",
      "preview": false,
      "preferMirrors": false,
      "mirrors": []
    }
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "chokidar": "^4.0.3",
    "extract-zip": "^2.0.1",
    "ffmpeg-static": "^5.3.0",
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "music-metadata": "^11.14.0",
    "node-7z": "^3.0.0",
    "youtubei.js": "^17.2.0"
  },
  "devDependencies": {
    "electron": "file:vendor/castlabs-electron",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "shinayuu": {
    "discord": {
      "applicationId": "",
      "largeImageKey": "shinayuu",
      "largeImageText": "ShinaYuu Music"
    },
    "displayVersion": "1.1.5",
    "runtime": {
      "engine": "castlabs-electron",
      "electronVersion": "42.5.2+wvcus",
      "widevineComponentUpdater": true,
      "spotifyPlayback": "main-renderer"
    },
    "youtube": {
      "oauthClientId": "",
      "oauthClientSecret": ""
    }
  },
  "license": "GPL-3.0-only"
}
